<?xml version="1.0"?>

<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>bluemoon@palemoon-theme</em:id>
    <em:version>1.1.0b8</em:version>

    <em:targetApplication>
      <Description>
        <em:id>{8de7fcbb-c55c-4fbe-bfc5-fc555c87dbc4}</em:id>
        <em:minVersion>29.3.0</em:minVersion>
        <em:maxVersion>34.*</em:maxVersion>
      </Description>
    </em:targetApplication>

    <em:name>Blue Moon</em:name>
    <em:description>Unofficial Pale Moon port derived from the Blue Ice Reloaded full theme.</em:description>
    <em:creator>Murry</em:creator>
    <em:contributor>Jivko Evgeniev</em:contributor>
    <em:contributor>Pale Moon port: Halvar</em:contributor>
    <em:homepageURL>https://web.archive.org/web/20170829132509/https://addons.mozilla.org/en-US/firefox/addon/blue-ice-reloaded/</em:homepageURL>
    <em:license>MPL-1.1</em:license>

    <em:internalName>bluemoon</em:internalName>
    <em:type>4</em:type>
    <em:unpack>true</em:unpack>
    <em:skinnable>true</em:skinnable>
  </Description>

</RDF>
